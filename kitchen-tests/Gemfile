source "https://rubygems.org"

# Kitchen tests only need the test drivers and inspec, not the full chef build
# The actual chef being tested is provided by appbundle-updater, which is already installed
# Avoid local path dependencies (gem "chef", path: "..") to prevent re-resolving the
# entire root Gemfile with its complex git dependencies (ohai, rest-client, etc.)

gem "kitchen-dokken", ">= 2.0"
gem "kitchen-vagrant", ">= 1.0"
gem "kitchen-inspec"
gem "inspec", ">= 5.0", "< 6"
gem "test-kitchen"
