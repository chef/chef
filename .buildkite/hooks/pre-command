#!/bin/bash

set -eu

# Only execute in the verify pipeline
[[ "$BUILDKITE_PIPELINE_NAME" =~ (verify|validate/(release|adhoc|canary))$ ]] || exit 0

docker ps || true

# Get chef foundation version from the json file
CHEF_FOUNDATION_VERSION=$(cat .buildkite-platform.json | jq -r '.chef_foundation')
export CHEF_FOUNDATION_VERSION
echo "Chef Foundation Version: $CHEF_FOUNDATION_VERSION"

OMNIBUS_TOOLCHAIN_VERSION=$(cat .buildkite-platform.json | jq -r '.omnibus_toolchain')
export OMNIBUS_TOOLCHAIN_VERSION
echo "Omnibus Toolchain Version: $OMNIBUS_TOOLCHAIN_VERSION"

if [[ "$BUILDKITE_STEP_KEY" == "build-windows-2019" ]] && [[ "$BUILDKITE_ORGANIZATION_SLUG" =~ chef(-canary)?$ ]]
then
  TOKEN=$(curl -sX PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")
  ROLE=$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" -v http://169.254.169.254/latest/meta-data/iam/security-credentials/)
  RESPONSE=$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" -v http://169.254.169.254/latest/meta-data/iam/security-credentials/$ROLE)
  AWS_ACCESS_KEY_ID=$(echo $RESPONSE | jq -r '.AccessKeyId')
  export AWS_ACCESS_KEY_ID
  AWS_SECRET_ACCESS_KEY=$(echo $RESPONSE | jq -r '.SecretAccessKey')
  export AWS_SECRET_ACCESS_KEY
  AWS_SESSION_TOKEN=$(echo $RESPONSE | jq -r '.Token')
  export AWS_SESSION_TOKEN
fi

# We've now seen cases where origin/main on the build hosts can get
# out of date. This causes us to build components unnecessarily.
# Fetching it here hopefully will prevent this situation.
echo "Fetching origin/main"
git fetch origin main

# DEBUGGING FOR RELENG
# Fetch the git tags to see if that addresses the weird smart build behavior for Habitat
git fetch --tags --force

# Rebase onto current main to ensure this PR is closer to what happens when it's merged.
# Only do this if it's actually a branch (i.e. a PR or a manually created build), not a
# post-merge CI run of main.
if [[ "$BUILDKITE_BRANCH" != "main" ]]; then
  git config user.email "you@example.com" # these are needed for the rebase attempt
  git config user.name "Your Name"
  main=$(git show-ref -s --abbrev origin/main)
  pr_head=$(git show-ref -s --abbrev HEAD)
  github="https://github.com/chef/chef/commit/"
  if git rebase origin/main >/dev/null; then
    buildkite-agent annotate --style success --context "rebase-pr-branch-${main}" \
      "Rebased onto main ([${main}](${github}${main}))."
  else
    git rebase --abort
    buildkite-agent annotate --style warning --context "rebase-pr-branch-${main}" \
      "Couldn't rebase onto main ([${main}](${github}${main})), building PR HEAD ([${pr_head}](${github}${pr_head}))."
  fi
fi

# For AIX builds, patch the root Gemfile.lock in-place so that pure-Ruby gem
# version lines match the AIX-compatible versions from Gemfile-aix.lock.
#
# The AIX omnibus toolchain ships Ruby 3.0; some gems in the main lockfile
# require Ruby >= 3.1.  omnibus/Gemfile.lock is committed with AIX-compatible
# pure-Ruby versions already patched (Windows platform-variant entries are kept
# at their original versions), so only the root lockfile needs runtime patching.
#
# The surgical sed only touches pure-version spec lines (digits+dots, no
# platform suffix like -x64-mingw-ucrt) to preserve Windows variants that
# Bundler's deployment-mode completeness check requires.
if [[ "${BUILDKITE_LABEL:-}" =~ aix ]]; then
  while IFS= read -r aix_line; do
    gem_name=$(echo "$aix_line" | sed 's/^    \([^ ]*\) .*/\1/')
    aix_ver=$(echo "$aix_line" | sed 's/.*(\([^)]*\))/\1/')
    esc_gem=$(printf '%s' "$gem_name" | sed 's/[].[\+^$()|{}/\\*?]/\\&/g')
    sed -i "s/^\(    ${esc_gem} \)([0-9][0-9.]*)$/\1(${aix_ver})/" Gemfile.lock
  done < <(grep '^    [a-z][a-z0-9_-]* ([0-9][0-9.]*)$' Gemfile-aix.lock)
fi

# For AIX build and test steps, pre-clean any dirty installp state on the remote
# AIX machine(s) before the omnibus-buildkite-plugin runs. The plugin uses
# installp to install chef-foundation (build) and the chef package (test); if a
# previous build was cancelled mid-installp the fileset is left in a dirty
# "incomplete operations" state and all subsequent installp invocations fail. We
# SSH to every AIX machine for the current agent queue (across both
# omnibus-toolchain and angry-omnibus-toolchain) and run `installp -C` which
# commits or rolls back any incomplete operations. Safe on clean machines (no-op).
# Errors here are non-fatal.
if [[ "${BUILDKITE_LABEL:-}" =~ aix ]] && \
   [[ "${BUILDKITE_ORGANIZATION_SLUG:-}" != "chef-oss" ]]; then
  echo "--- AIX build: pre-cleaning installp state on remote AIX machine(s)"
  (
    set +eu
    # Plugin JSON is available after plugin post-checkout hook runs (before pre-command)
    PLATFORMS_JSON="$(ls /var/lib/buildkite-agent/plugins/github-com-chef-omnibus-buildkite-plugin-*/files/esoteric-omnibus-platforms.json 2>/dev/null | head -1)"
    if [[ ! -f "${PLATFORMS_JSON:-}" ]]; then
      echo "AIX pre-cleanup: plugin JSON not found, skipping"
      exit 0
    fi

    # Collect all AIX hostnames for this queue from all toolchain entries
    AIX_HOSTS="$(jq -r --arg q "${BUILDKITE_AGENT_META_DATA_QUEUE:-}" \
      '.[] | .[$q] // empty' "$PLATFORMS_JSON" 2>/dev/null)"
    if [[ -z "${AIX_HOSTS:-}" ]]; then
      echo "AIX pre-cleanup: no hosts for queue '${BUILDKITE_AGENT_META_DATA_QUEUE:-}', skipping"
      exit 0
    fi

    # Authenticate to Vault (same method as omnibus-buildkite-plugin)
    VAULT_ADDR="https://vault.ps.chef.co"
    VAULT_TOKEN="$(VAULT_ADDR="$VAULT_ADDR" vault login \
      -method=aws -path=aws/private-cd -token-only \
      header_value=vault.ps.chef.co role=omnibus-secrets 2>/dev/null)"
    if [[ -z "${VAULT_TOKEN:-}" ]]; then
      echo "AIX pre-cleanup: Vault auth failed, skipping"
      exit 0
    fi

    SSH_KEY="$(VAULT_ADDR="$VAULT_ADDR" VAULT_TOKEN="$VAULT_TOKEN" \
      vault read -field=ssh_private_key account/static/esoteric/chef-ci 2>/dev/null)"
    if [[ -z "${SSH_KEY:-}" ]]; then
      echo "AIX pre-cleanup: could not retrieve SSH key, skipping"
      exit 0
    fi

    AIX_KEY_FILE="$(mktemp /tmp/aix-cleanup-key-XXXXXX)"
    echo "$SSH_KEY" > "$AIX_KEY_FILE"
    chmod 600 "$AIX_KEY_FILE"

    # Run installp -C on every AIX machine for this queue in parallel
    while IFS= read -r host; do
      [[ -z "$host" ]] && continue
      echo "  Running installp -C on $host"
      ssh -i "$AIX_KEY_FILE" \
        -o StrictHostKeyChecking=no \
        -o ServerAliveInterval=30 \
        -o ConnectTimeout=30 \
        "chef-ci@${host}" \
        "sudo /usr/sbin/installp -C 2>&1; true" &
    done <<< "$AIX_HOSTS"
    wait

    rm -f "$AIX_KEY_FILE"
    echo "AIX pre-cleanup: installp -C complete on all hosts"
  ) || echo "AIX pre-cleanup: encountered errors (non-fatal, continuing)"
fi

# Only if on chef-canary or chef org
# force regions on omnibus queues
[[ $BUILDKITE_ORGANIZATION_SLUG != "chef-oss" ]] && if [[ $BUILDKITE_ORGANIZATION_SLUG = "chef" ]]; then
  export AWS_REGION="us-west-2"
else
  export AWS_REGION="us-west-1"
fi

if [[ ! "$BUILDKITE_STEP_KEY" =~ ^test.* ]] && [[ $BUILDKITE_ORGANIZATION_SLUG != "chef-oss" ]]; then

  if [[ ! $BUILDKITE_LABEL =~ macOS|mac_os_x ]]; then
    lita_password=$(aws ssm get-parameter --name "artifactory-lita-password" --with-decryption --query Parameter.Value --output text --region ${AWS_REGION})
    export ARTIFACTORY_API_KEY=$(echo -n "lita:${lita_password}" | base64)
  fi
  export ARTIFACTORY_PASSWORD=$(aws ssm get-parameter --name "buildkite-artifactory-docker-full-access-token" --query Parameter.Value --with-decryption --output text --region ${AWS_REGION})

  # Only if on RPM-based Linux distros
  if [[ "$BUILDKITE_LABEL" =~ rhel|rocky|sles|centos|amazon ]]; then
    export RPM_SIGNING_KEY=$(aws ssm get-parameter --name "packages-at-chef-io-signing-cert" --with-decryption --query Parameter.Value --output text --region ${AWS_REGION})
  fi
fi

if [[ "$BUILDKITE_STEP_KEY" =~ ^build-.* ]] && [[ "$BUILDKITE_ORGANIZATION_SLUG" =~ chef(-canary)?$ ]] && [[ ! $BUILDKITE_LABEL =~ macOS|mac_os_x ]]; then
    # Set AWS S3 credentials for omnibus cache operations
    AWS_S3_ACCESS_KEY=$(aws ssm get-parameter --name "omnibus-cache-aws-access-key-id-private" --with-decryption --region "${AWS_REGION}" --query Parameter.Value --output text)
    export AWS_S3_ACCESS_KEY
    
    AWS_S3_SECRET_KEY=$(aws ssm get-parameter --name "omnibus-cache-aws-secret-access-key-id-private" --with-decryption --region "${AWS_REGION}" --query Parameter.Value --output text)
    export AWS_S3_SECRET_KEY
    
    echo "AWS S3 credentials set for omnibus cache operations"
fi
