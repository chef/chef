#!/bin/bash
set -euo pipefail

echo "=== DEBUG: pre-command hook ==="
echo "WORKDIR=$(pwd)"
echo "whoami=$(whoami)"
echo "HOME=${HOME:-<unset>}"
echo "BUNDLE_GEMFILE=${BUNDLE_GEMFILE:-<unset>}"
echo "BUNDLE_APP_CONFIG=${BUNDLE_APP_CONFIG:-<unset>}"

# Show whether token exists, without leaking it
if [[ -n "${OMNIBUS_SUBMODULE_CONFIG_PRIVATE:-}" ]]; then
  echo "OMNIBUS_SUBMODULE_CONFIG_PRIVATE is set (len=${#OMNIBUS_SUBMODULE_CONFIG_PRIVATE})"
else
  echo "OMNIBUS_SUBMODULE_CONFIG_PRIVATE is NOT set"
fi

echo "--- tool versions (if present) ---"
command -v ruby >/dev/null 2>&1 && ruby -v || echo "ruby not found"
command -v bundle >/dev/null 2>&1 && bundle -v || echo "bundler not found"
command -v git >/dev/null 2>&1 && git --version || echo "git not found"

# Fail fast if git ever tries to prompt for credentials (prevents “hang”)
export GIT_TERMINAL_PROMPT=0

# Light-touch Bundler diagnostics (doesn't print token value unless it's already stored)
echo "--- bundler config list (before) ---"
command -v bundle >/dev/null 2>&1 && bundle config list || true

echo "=== END DEBUG: pre-command hook ==="

# Configure Bundler to authenticate to GitHub for private gem sources / git-based deps
# (preferred over rewriting git https URLs globally)
if [[ -n "${OMNIBUS_SUBMODULE_CONFIG_PRIVATE:-}" ]]; then
  # Keep it local to the repo to avoid leaking into other jobs
  bundle config set --local github.com "x-access-token:${OMNIBUS_SUBMODULE_CONFIG_PRIVATE}"
else
  echo "No OMNIBUS_SUBMODULE_CONFIG_PRIVATE secret set. Skipping private repo config."
fi

echo "--- bundler config dir exists? ---"
ls -la .bundle || true
# NOTE: intentionally NOT printing .bundle/config to avoid leaking secrets into logs
