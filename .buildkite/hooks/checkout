#!/bin/bash

# Configure GitHub HTTPS auth early so private submodules can be cloned during checkout
if [[ -n "${OMNIBUS_SUBMODULE_CONFIG_PRIVATE:-}" ]]; then
  # Keep it local to the repo to avoid leaking into other jobs
  bundle config set --local github.com "x-access-token:${OMNIBUS_SUBMODULE_CONFIG_PRIVATE}"
else
  echo "No OMNIBUS_SUBMODULE_CONFIG_PRIVATE secret set. Skipping private repo config."
fi